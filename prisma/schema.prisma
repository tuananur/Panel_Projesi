generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String?  // Nullable, if null requires setting password
  role      String   @default("DESIGNER") // "ADMIN", "DESIGNER", "ADVERTISER"
  logs      ActivityLog[]
  notes     Note[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Client {
  id          Int      @id @default(autoincrement())
  companyName String
  website     String?
  contactName String
  email       String?
  phone       String
  services    String   // JSON or comma separated e.g. "SEO,SOCIAL_MEDIA"
  
  // Phase 2 fields
  weeklyBlogTarget   Int?    @default(0)
  socialAccounts     String? @db.Text
  socialSchedule     String? @db.Text
  specialInstructions String? @db.Text
  logoUrl            String? @db.Text
  
  // Website Integration
  websiteType        String? @default("OTHER") // "BEYIN_ATOLYESI", "IDEASOFT", "OTHER"
  blogApiUrl         String? @db.Text
  
  tasks            Task[]
  logs             ActivityLog[]
  notes            Note[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Task {
  id        Int      @id @default(autoincrement())
  clientId  Int
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  date      DateTime // Date for the post/blog
  type      String   // "BLOG" or "SOCIAL"
  platform  String?  // Only for social e.g., "Instagram", "YouTube"
  note      String?  @db.Text // Descriptive note for the task
  content   String?  @db.Text // Blog content or body
  link      String?  @db.Text // Link to the specific post
  status    Boolean  @default(false) // false = pending, true = completed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ActivityLog {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  clientId    Int?
  client      Client?  @relation(fields: [clientId], references: [id])
  action      String   // "CREATE", "UPDATE", "DELETE", "TOGGLE"
  entityType  String   // "TASK", "CLIENT", "USER", "NOTE"
  details     String   @db.Text
  createdAt   DateTime @default(now())
}

model Note {
  id        Int      @id @default(autoincrement())
  clientId  Int
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  title     String?
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

