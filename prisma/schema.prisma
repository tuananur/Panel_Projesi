generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int             @id @default(autoincrement())
  username          String          @unique
  password          String?
  role              String          @default("DESIGNER") // "ADMIN", "DESIGNER", "DESIGNER_MANAGER", "ADVERTISER", "ADVERTISER_MANAGER", "DEVELOPER"
  managerId         Int?
  manager           User?           @relation("UserManager", fields: [managerId], references: [id], onDelete: SetNull)
  managedUsers      User[]          @relation("UserManager")
  logs              ActivityLog[]
  notes             Note[]          @relation("NoteAssignee")
  createdNotes      Note[]          @relation("NoteCreator")
  assignedWorkItems WorkItem[]      @relation("WorkItemAssignee")
  createdWorkItems  WorkItem[]      @relation("WorkItemCreator")
  approvedWorkItems WorkItem[]      @relation("WorkItemApprover")
  workItemEvents    WorkItemEvent[]
  notifications     Notification[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([managerId])
}

model Client {
  id          Int     @id @default(autoincrement())
  companyName String
  website     String?
  contactName String
  email       String?
  phone       String?
  services    String // JSON or comma separated e.g. "SEO,SOCIAL_MEDIA"

  // Phase 2 fields
  weeklyBlogTarget    Int?    @default(0)
  socialAccounts      String? @db.Text
  socialSchedule      String? @db.Text
  specialInstructions String? @db.Text
  logoUrl             String? @db.Text

  // Website Integration
  websiteType String? @default("OTHER") // "BEYIN_ATOLYESI", "IDEASOFT", "OTHER"
  blogApiUrl  String? @db.Text

  tasks                   Task[]
  logs                    ActivityLog[]
  notes                   Note[]
  workItems               WorkItem[]
  metaArmyCommands        MetaArmyCommand[]
  metaArmyRuns            MetaArmyRun[]
  metaArmyFindings        MetaArmyFinding[]
  metaArmyRecommendations MetaArmyRecommendation[]

  // Meta Ads Integration
  metaEnabled     Boolean @default(false)
  metaAdAccountId String? @db.Text
  metaAccessToken String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MetaArmyCommand {
  id          Int           @id @default(autoincrement())
  clientId    Int
  client      Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  command     String        @db.Text
  status      String        @default("QUEUED") // "QUEUED", "IN_PROGRESS", "COMPLETED", "FAILED", "CANCELLED"
  priority    String        @default("NORMAL") // "LOW", "NORMAL", "HIGH", "URGENT"
  source      String        @default("PANEL")
  requestedBy String?
  result      String?       @db.Text
  runs        MetaArmyRun[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model MetaArmyRun {
  id              Int                      @id @default(autoincrement())
  clientId        Int
  client          Client                   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  commandId       Int?
  command         MetaArmyCommand?         @relation(fields: [commandId], references: [id], onDelete: SetNull)
  agentName       String
  status          String                   @default("QUEUED") // "QUEUED", "RUNNING", "COMPLETED", "FAILED", "WAITING_APPROVAL"
  summary         String?                  @db.Text
  rawOutput       String?                  @db.Text
  startedAt       DateTime?
  completedAt     DateTime?
  findings        MetaArmyFinding[]
  recommendations MetaArmyRecommendation[]
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
}

model MetaArmyFinding {
  id          Int          @id @default(autoincrement())
  clientId    Int
  client      Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  runId       Int?
  run         MetaArmyRun? @relation(fields: [runId], references: [id], onDelete: SetNull)
  severity    String       @default("INFO") // "INFO", "LOW", "MEDIUM", "HIGH", "CRITICAL"
  category    String       @default("PERFORMANCE")
  title       String
  details     String       @db.Text
  evidence    String?      @db.Text
  metricsJson String?      @db.Text
  createdAt   DateTime     @default(now())
}

model MetaArmyRecommendation {
  id             Int          @id @default(autoincrement())
  clientId       Int
  client         Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  runId          Int?
  run            MetaArmyRun? @relation(fields: [runId], references: [id], onDelete: SetNull)
  actionType     String
  status         String       @default("PENDING_APPROVAL") // "PENDING_APPROVAL", "APPROVED", "REJECTED", "EXECUTED", "FAILED"
  title          String
  details        String       @db.Text
  expectedImpact String?      @db.Text
  riskLevel      String       @default("MEDIUM")
  actionPayload  String?      @db.Text
  approvedBy     String?
  approvalText   String?      @db.Text
  approvedAt     DateTime?
  executedAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Task {
  id        Int      @id @default(autoincrement())
  clientId  Int
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  date      DateTime // Date for the post/blog
  type      String // "BLOG" or "SOCIAL"
  platform  String? // Only for social e.g., "Instagram", "YouTube"
  note      String?  @db.Text // Descriptive note for the task
  content   String?  @db.Text // Blog content or body
  link      String?  @db.Text // Link to the specific post
  status    Boolean  @default(false) // false = pending, true = completed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ActivityLog {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId   Int?
  client     Client?  @relation(fields: [clientId], references: [id])
  action     String // "CREATE", "UPDATE", "DELETE", "TOGGLE"
  entityType String // "TASK", "CLIENT", "USER", "NOTE"
  details    String   @db.Text
  createdAt  DateTime @default(now())
}

model Note {
  id              Int      @id @default(autoincrement())
  clientId        Int? // Null = Genel Not
  client          Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId          Int
  user            User     @relation("NoteAssignee", fields: [userId], references: [id], onDelete: Cascade)
  createdByUserId Int?
  createdByUser   User?    @relation("NoteCreator", fields: [createdByUserId], references: [id])
  title           String?
  content         String   @default("") @db.Text
  category        String   @default("TASK") // "TASK" (iş takibi) | "DEV" (yazılım)
  isDone          Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model WorkItem {
  id          Int       @id @default(autoincrement())
  title       String
  description String?   @db.Text
  dueDate     DateTime?
  priority    String    @default("NORMAL") // "LOW", "NORMAL", "HIGH", "URGENT"
  type        String    @default("OTHER")
  status      String    @default("ASSIGNED") // "ASSIGNED", "IN_PROGRESS", "SUBMITTED", "APPROVED", "REVISION_REQUESTED", "CANCELLED"

  clientId     Int?
  client       Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  assigneeId   Int
  assignee     User    @relation("WorkItemAssignee", fields: [assigneeId], references: [id], onDelete: Cascade)
  createdById  Int
  createdBy    User    @relation("WorkItemCreator", fields: [createdById], references: [id], onDelete: Cascade)
  approvedById Int?
  approvedBy   User?   @relation("WorkItemApprover", fields: [approvedById], references: [id], onDelete: SetNull)

  submittedAt        DateTime?
  approvedAt         DateTime?
  lastSubmissionNote String?   @db.Text
  lastRevisionNote   String?   @db.Text
  unreadForUserIds   String    @default("[]") @db.Text

  events    WorkItemEvent[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([assigneeId, status])
  @@index([createdById, status])
  @@index([clientId])
}

model WorkItemEvent {
  id         Int      @id @default(autoincrement())
  workItemId Int
  workItem   WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       String // "CREATED", "STARTED", "SUBMITTED", "APPROVED", "REVISION_REQUESTED", "CANCELLED"
  note       String?  @db.Text
  createdAt  DateTime @default(now())

  @@index([workItemId])
}

model Notification {
  id        Int       @id @default(autoincrement())
  userId    Int
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String    @db.Text
  url       String?   @db.Text
  type      String    @default("GENERAL")
  dedupeKey String?   @unique
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt, createdAt])
}

model AccountingEntry {
  id          Int      @id @default(autoincrement())
  type        String // "INCOME" or "EXPENSE"
  amount      Float
  description String
  category    String?
  date        DateTime
  frequency   String   @default("MANUAL") // "MANUAL", "MONTHLY", "QUARTERLY", "YEARLY"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Setting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}
